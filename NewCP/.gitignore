/target/

# Local debug / phase-dump artifacts produced by the driver and test runs.
# These are useful while iterating but should never be committed.
*.log
*.ll
/app_ir.txt
/build_output.txt
/out.log
/out.txt

# HostFiles round-trip test artifacts (each test writes + deletes its
# own bin file in cwd, but a crashed test can leave one behind).
/tests/newcp-tests/*.bin
