/target/

# Local debug / phase-dump artifacts produced by the driver and test runs.
# These are useful while iterating but should never be committed.
*.log
*.ll
/app_ir.txt
/build_output.txt
/out.log
/out.txt

# HostFiles round-trip test artifacts (each test writes + deletes its
# own bin file in cwd, but a crashed test can leave one behind).
/tests/newcp-tests/*.bin

# Scratch / probe artifacts left by test runs and driver sessions.
*probe_stdout.txt
*probe_stderr.txt
_pixels_sweep.txt
test_render.png
textviews_probe_tail.txt
*.png

# Scratch CP modules (T6, T7, T8, TinyDemo*) — uncommitted throwaway files.
/Mod/T[0-9]*.cp
/Mod/TinyDemo*.cp
